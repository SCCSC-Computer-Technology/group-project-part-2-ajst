@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>

    .form-control::placeholder {
        text-align: center;
    }

</style>

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-md-4">
        <h1 class="d-flex justify-content-center align-items-center">@ViewData["Title"]</h1>
        <section>
            <form id="account" method="post">
                <h2 class="text-center">Use a local account to log in.</h2>
                <hr />
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                <div class="mb-3">
                    <label asp-for="Input.Name" class="form-label">Name</label>

                    <div class="input-group">
                        <input asp-for="Input.Name"
                               class="form-control"
                               aria-required="true"
                               placeholder="Jerry Springer" />
                    </div>

                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label">Email</label>

                    <div class="input-group">
                        <input asp-for="Input.Email"
                               class="form-control"
                               autocomplete="username"
                               aria-required="true"
                               placeholder="example@email.com" />
                    </div>

                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Password</label>
                <div class="input-group">
                    <input asp-for="Input.Password"
                            class="form-control"
                            id="registerPassword"
                            autocomplete="new-password"
                            aria-required="true"
                            placeholder="Enter password" />

                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePassword('registerPassword', this)">
                        Show
                    </button>
                </div>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.ConfirmPassword" class="form-label">Confirm Password</label>
                <div class="input-group">
                    <input asp-for="Input.ConfirmPassword"
                            class="form-control"
                            id="confirmPassword"
                            autocomplete="new-password"
                            aria-required="true"
                            placeholder="Confirm password" />

                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePassword('confirmPassword', this)">
                        Show
                    </button>
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>
            <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary">Register</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

        <script>
            function togglePassword(inputId, button) {
                var input = document.getElementById(inputId);

                if (input.type === "password") {
                    input.type = "text";
                    button.innerText = "Hide";
                } else {
                    input.type = "password";
                    button.innerText = "Show";
                }
            }
        </script>

}
