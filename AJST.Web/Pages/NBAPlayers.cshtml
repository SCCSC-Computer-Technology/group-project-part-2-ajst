@page
@model WebApp.Pages.NBAPlayersModel
@{
    ViewData["Title"] = "NBA Players";
}

<h1>NBA Players</h1>



@* get all team names and put them into their own links *@
<div class="team-grid">
    @foreach (var team in Model.Teams)
    {
        <a asp-page="/NBAPlayers" asp-route-TeamID="@team.NBATeamID" class="team-item">
            @team.TeamName
        </a>
    }
</div>

<p>
    <a asp-page="/NBAPlayers" class="team-item">All Players</a>
</p>

<h3>@Model.SelectedTeamName</h3>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Position</th>
            <th>Height</th>
            <th>Weight</th>
            <th>Years In League</th>
            <th>Birth Year</th>
            <th>Born In</th>
            <th>Draft Year</th>
            <th>Draft Round</th>
            <th>Draft Pick</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var player in Model.Players)
        {
            <tr>
                <td>@player.Name</td>
                <td>@player.Position</td>
                <td>@player.Height</td>
                <td>@player.Weight</td>
                <td>@player.YearsInLeague</td>
                <td>@player.BirthYear</td>
                <td>@player.BornIn</td>
                <td>@player.DraftYear</td>
                <td>@player.DraftRound</td>
                <td>@player.DraftPick</td>
            </tr>
        }
    </tbody>
</table>