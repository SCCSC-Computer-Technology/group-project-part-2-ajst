@page
@model WebApp.Pages.NBAStatsModel
@{
    ViewData["Title"] = "NBA Season Stats";
}
<head>
<style>
table, th, td {
  border: 1px solid gray;
}
</style>
</head>
<div class="row">
    <h1 class="display-2">NBA SEASON STATS</h1>
    <table class="table table-striped">
        <thead class="thead-inverse">
            <tr>
                        <th>Team</th>
                        <th>Games Played</th>
                        <th>Wins</th>
                        <th>Losses</th>
                        <th>Game Time</th>
                        <th>Points Per Game</th>
                        <th>Field Goal %</th>
                        <th>Three Point %</th>
                        <th>Free Throw %</th>
                        <th>Rebounds</th>
                        <th>Assists</th>
                        <th>Turnovers</th>
                        <th>Steals</th>
                        <th>Blocks</th>
                        <th>Fouls</th>
                        
            </tr>
        </thead>
        <tbody></tbody>
            @if (Model.Stats is not null)
            {
                @foreach (var s in Model.Stats)
                {
                    <tr>
                        <th>@s.Team</th>
                        <th>@s.Games_Played</th>
                        <th>@s.Wins</th>
                        <th>@s.Losses</th>
                        <th>@s.Minutes_Per_Game</th>
                        <th>@s.Points_Per_Game</th>
                        <th>@s.Field_Goal_Percentage</th>
                        <th>@s.Three_Point_Percentage</th>
                        <th>@s.Free_Throw_Percentage</th>
                        <th>@s.Total_Rebounds</th>
                        <th>@s.Assists</th>
                        <th>@s.Turnovers</th>
                        <th>@s.Steals</th>
                        <th>@s.Blocks</th>
                        <th>@s.Personal_Fouls</th>
                    </tr>
                }
            }
        </tbody>
    </table
</div>
