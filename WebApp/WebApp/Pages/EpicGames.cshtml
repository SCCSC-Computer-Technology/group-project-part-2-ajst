@page
@model WebApp.Pages.EpicGamesModel
@{
    ViewData["Title"] = "Epic Games Launcher";
}

<style>
    body {
        background-color: #0e0e0e;
        color: white;
        font-family: Arial, sans-serif;
        text-align: center;
    }

    .container {
        margin-top: 60px;
    }

    .card {
        background-color: #1c1c1c;
        padding: 30px;
        border-radius: 15px;
        width: 400px;
        margin: auto;
        box-shadow: 0 0 20px rgba(0,0,0,0.6);
        color: white;
    }

        .card img {
            width: 120px;
            margin-bottom: 20px;
        }

    h1 {
        margin-bottom: 10px;
        color: white;
    }

    .tagline {
        color: #ddd;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
        text-align: left;
    }

        .form-group label {
            font-size: 14px;
            color: #ddd;
        }

    .form-control {
        width: 100%;
        padding: 8px;
        border-radius: 5px;
        border: none;
        margin-top: 5px;
    }

    .btn-epic {
        width: 100%;
        padding: 10px;
        background-color: #0074e4;
        border: none;
        border-radius: 6px;
        color: white;
        font-weight: bold;
        margin-top: 15px;
    }

        .btn-epic:hover {
            background-color: #005bb5;
        }

    .warning {
        font-size: 12px;
        color: #777;
        margin-top: 15px;
    }
</style>

<div class="container">
    <div class="card">

        <img src="~/images/epicgames.jpg" alt="Epic Games Logo" />

        <h1>Epic Games Launcher</h1>
        <p class="tagline">Install now and unlock Alpha Boost (not guaranteed)</p>

        <form>
            <div class="form-group">
                <label>Epic Username</label>
                <input class="form-control" placeholder="Enter Here" />
            </div>

            <div class="form-group">
                <label>Desired Competitive Rank (FREE!!!)</label>
                <input class="form-control" placeholder="Bronze 1 - Supersonic Legend" />
            </div>

            <div class="form-group">
                <label>How many hours have you played (be honest)</label>
                <input class="form-control" type="number" />
            </div>

            <button type="button" class="btn-epic"
                    onclick="installGame()">
                Install Now
            </button>
        </form>

        <p class="warning">*By clicking install, you agree to blame lag for all losses.</p>

    </div>
</div>

<script>
    function installGame() {
        alert("Installing...\n\nDownload failed.\nReason: CRUCIAL!! Enter in your information on the rocket league ad first! \nSo you can play for free!!");
    }
</script>