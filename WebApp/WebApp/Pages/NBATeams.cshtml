@page
@model WebApp.Pages.NBATeamsModel
@{
    ViewData["Title"] = "NBA Teams";
}

<h1>NBA Teams</h1>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Team Name</th>
            <th>Abbreviation</th>
            <th>Conference</th>
            <th>Arena</th>
            <th>Wins</th>
            <th>Losses</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var team in Model.Teams)
        {
            <tr>
                <td>@team.TeamName</td>
                <td>@team.Abbreviation</td>
                <td>@team.Conference</td>
                <td>@team.Arena</td>
                <td>@team.Wins</td>
                <td>@team.Losses</td>
            </tr>
        }
    </tbody>
</table>